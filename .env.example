# =============================================
# MarketingAlphaScan Environment Variables
# =============================================
# Copy this file to .env.local (web) and .env (engine)
# Never commit real values to version control

# === SHARED ===
NODE_ENV=development

# === FRONTEND (apps/web/.env.local) ===

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Canonical site URL (used in emails, share links, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Engine communication
ENGINE_URL=http://localhost:3001
ENGINE_HMAC_SECRET=replace-with-64-char-hex-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_ALPHA_BRIEF_PRICE_ID=price_...
STRIPE_CHAT_CREDITS_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# Google Gemini AI (for AI Chat)
GOOGLE_AI_API_KEY=AI...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@marketingalphascan.com
RESEND_WEBHOOK_SECRET=whsec_...

# Internal API authentication (email trigger endpoint)
INTERNAL_API_SECRET=replace-with-64-char-hex-secret

# JWT secret for email unsubscribe tokens
UNSUBSCRIBE_JWT_SECRET=replace-with-32-char-secret

# Supabase Send Email Hook (HMAC signature verification)
SUPABASE_SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# === ENGINE (apps/engine/.env) ===

# Server
PORT=3001
# ENGINE_HMAC_SECRET= (same as frontend)

# Supabase (service role — bypasses RLS)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis
REDIS_URL=redis://localhost:6379

# Google Gemini AI
GOOGLE_AI_API_KEY=AI...

# DataForSEO
DATAFORSEO_LOGIN=your-login
DATAFORSEO_PASSWORD=your-password

# Google PageSpeed Insights / CrUX (optional — works without key, rate-limited)
GOOGLE_PSI_API_KEY=

# PostHog (server-side)
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Admin
ADMIN_TOKEN=replace-with-64-char-hex-secret
