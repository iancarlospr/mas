{
  "name": "@marketing-alpha/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project engine",
    "test:unit": "vitest run --project engine",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:golden": "RUN_GOLDEN=true vitest run --project engine --testPathPattern golden",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@google/genai": "^1.46.0",
    "@marketing-alpha/types": "*",
    "@supabase/supabase-js": "^2.100.0",
    "bullmq": "^5.71.0",
    "cheerio": "^1.0.0",
    "fastify": "^5.8.4",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.4.1",
    "patchright": "^1.58.2",
    "pdf-lib": "^1.17.1",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
    "sharp": "^0.34.5",
    "posthog-node": "^5.28.5",
    "tldts": "^6.1.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
