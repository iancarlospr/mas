{
  "name": "@marketing-alpha/video",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.tsx",
    "render": "remotion render src/index.tsx MarketingReel --output out/reel.mp4",
    "render:progression": "remotion render src/index.tsx ProgressionReel --output out/progression.mp4",
    "render:gif": "remotion render src/index.tsx MarketingReel --output out/reel.gif --codec gif",
    "render:demo": "remotion render src/index.tsx AppDemo --output out/app-demo.mp4",
    "render:still": "remotion still src/index.tsx MarketingReel --output out/thumbnail.png --frame 0",
    "build": "echo 'video package — no build step'"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@remotion/cli": "^4.0.0",
    "@remotion/noise": "^4.0.438",
    "@remotion/paths": "^4.0.0",
    "@remotion/tailwind": "^4.0.0",
    "@remotion/three": "^4.0.436",
    "@remotion/transitions": "^4.0.0",
    "@types/three": "^0.183.1",
    "postprocessing": "^6.39.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
